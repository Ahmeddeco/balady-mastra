generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/generated"
  useMultipleFiles                 = true
  writeNullishInModelTypes         = true
  createModelTypes                 = true
  writeBarrelFiles                 = false
  createInputTypes                 = false
  addInputTypeValidation           = false
  addIncludeType                   = false
  addSelectType                    = false
  validateWhereUniqueInput         = false
  createOptionalDefaultValuesTypes = false
  createRelationValuesTypes        = false
  createPartialTypes               = false
  useDefaultValidators             = false
  coerceDate                       = false
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  role            Role            @default(user)
  accounts        Account[]
  sessions        Session[]
  Authenticator   Authenticator[]
  personalId      String?
  primaryMobile   String?         @unique
  secondaryMobile String?
  country         String?
  state           String?
  city            String?
  detailedAddress String?
  lat             String?
  lng             String?
  orders          Order[]
  favorites       Favorite[]
  farm            Farm[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  title         String      @unique
  slug          String      @unique
  description   String
  cut           MeatType
  category      Category
  mainImage     String
  images        String[]
  price         Float       @default(0) // تعديل إلى Float للدقة المالية
  discount      Int?        @default(0)
  unit          Unit        @default(kg) // اللحوم تباع بالوزن غالباً كإجراء افتراضي
  stock         Float       @default(0) // تعديل إلى Float لحسابات تشفي الأوزان
  lowQuantity   Float?      @default(0)
  increaseByOne Boolean     @default(false)
  isActive      Boolean     @default(true) // مضاف: لإيقاف البيع دون حذف المنتج وتخريب سجل الطلبات القديمة
  orderItems    OrderItem[]
  favorites     Favorite[]
  cattleId      String? // جعلناه اختياري لبيع المصنعات أو الدواجن أو اللحوم العامة دون ربطها برأس ماشية عينية
  Cattle        Cattle?     @relation(fields: [cattleId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([cut])
}

model Farm {
  id              String   @id @default(cuid())
  name            String   @unique
  manager         User     @relation(fields: [userId], references: [id])
  cattle          Cattle[]
  country         String? // تصحيح الخطأ الإملائي conuntry -> country
  state           String?
  city            String?
  detailedAddress String?
  lat             String?
  lng             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
}

model Breed {
  id             String     @id @default(cuid())
  name           String     @unique
  description    String?
  type           CattleType @default(cow)
  conversionRate Float?
  image          String
  images         String[]
  cattle         Cattle[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Cattle {
  id            String       @id @default(cuid())
  farm          Farm         @relation(fields: [farmId], references: [id])
  farmId        String
  breed         Breed        @relation(fields: [breedId], references: [id])
  breedId       String
  description   String?
  image         String?
  images        String[]
  gender        Gender       @default(male)
  age           Age          @default(young)
  liveWeight    Float? // مضاف: الوزن القائم للرأس وهو أساسي للمزارع والتجارة
  costPrice     Float? // مضاف: تكلفة شراء الرأس لحساب الأرباح بدقة
  product       Product[]
  yieldReport   YieldReport?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  yieldReportId String

  @@index([farmId])
  @@index([breedId])
}

model YieldReport {
  id               String   @id @default(cuid())
  cattle           Cattle   @relation(fields: [cattleId], references: [id])
  cattleId         String   @unique
  hotCarcassWeight Float
  boneWeight       Float
  fatWeight        Float
  wasteWeight      Float
  netYieldWeight   Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     Int           @unique @default(autoincrement())
  subTotal        Float // تعديل إلى Float منعاً لكسور الـ Float المالية
  deliveryFee     Float         @default(0)
  total           Float
  finalTotal      Float? //يتم تسجيله فقط بعد قيام الجزار بالوزن الفعلي، وهو القيمة الحقيقية اللي هيدفعها العميل كاش أو تتخصم من الفيزا
  status          OrderStatus   @default(pending)
  paymentMethod   PaymentMethod @default(cash)
  paymentStatus   PaymentStatus @default(pending)
  shippingAddress String
  customerNotes   String? // مثال: "تقطيع المكعبات صغير للطبخ"
  butcherNotes    String? // ملاحظات داخلية للجزار أثناء التجهيز والتعبئة والتشفية
  items           OrderItem[]
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
}

model OrderItem {
  id                String      @id @default(cuid())
  preparation       Preparation
  quantity          Float // الكمية المطلوبة (بالوزن أو القطعة)
  price             Float // سعر المنتج وقت الشراء الفعلي لضمان ثبات التقارير المالية
  requestedQuantity Float // الوزن المحجوز من الموقع (مثال: 1.00 كجم)
  actualQuantity    Float? // الوزن الحقيقي الخارج من الميزان بعد التشفية (مثال: 1.050 كجم)
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade) // حذف العناصر تلقائياً عند حذف الطلب
  orderId           String
  product           Product     @relation(fields: [productId], references: [id], onDelete: Restrict) // منع حذف المنتج إذا كان متواجداً في طلبات قديمة
  productId         String

  @@index([orderId])
  @@index([productId])
}

model Favorite {
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // إذا حُذف المنتج تُحذف من المفضلة
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // إذا حُذف المستخدم تُحذف مفضلته
  userId    String
  createdAt DateTime @default(now())

  @@id([userId, productId])
}

enum CattleType {
  cow // أبقار
  buffalo // جاموس
  goat // ماعز
  sheep // غنم
  camel // جمال
}

enum Age {
  young // صغير (لباني)
  medium // وسيط (كاسر جوز / أربعة)
  adult // كبير (جامع)
}

enum Gender {
  male // ذكر
  female // أنثى
}

enum MeatType {
  chuck // سن
  shank // موزة
  ribs // ريش
  topside // وش فخدة
  silverside // ضهر فخدة
  knuckle // سمانة
  ribeye // انتركوت
  eye_round // تربيانكو
  blade // لوحة الكتف
  brisket // دوش
  liver // كبدة
  heart // قلب
  kidneys // كلاوي
  tenderloin // فلتو
  flank // السرة
  processed // مصنعات
  chicken_breast // صدور دواجن
  chicken_thigh // أوراك دواجن
}

enum Preparation {
  escalope // بفتيك
  steak // ستيك
  cubes // مكعبات
  kabab_hala // كباب حلة
  slices // شرائح
  minced // مفروم
  whole // كامل (للعروق كاملة أو الطيور الكاملة)
}

enum Role {
  admin
  user
  client
  supplier
}

enum Category {
  meat
  processed
  chicken
}

enum Unit {
  kg // كجم
  piece // قطعة
}

enum OrderStatus {
  pending
  shipped
  completed
  cancelled
}

enum PaymentMethod {
  visa
  cash
}

enum PaymentStatus {
  pending
  success
  failed
}
