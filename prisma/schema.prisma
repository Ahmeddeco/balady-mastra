generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/generated"
  useMultipleFiles                 = true
  writeNullishInModelTypes         = true
  createModelTypes                 = true
  writeBarrelFiles                 = false
  createInputTypes                 = false
  addInputTypeValidation           = false
  addIncludeType                   = false
  addSelectType                    = false
  validateWhereUniqueInput         = false
  createOptionalDefaultValuesTypes = false
  createRelationValuesTypes        = false
  createPartialTypes               = false
  useDefaultValidators             = false
  coerceDate                       = false
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  role            Role            @default(USER)
  accounts        Account[]
  sessions        Session[]
  Authenticator   Authenticator[]
  personalId      String?
  primaryMobile   String?         @unique
  secondaryMobile String?
  country         String?
  state           String?
  city            String?
  detailedAddress String?
  orders          Order[]
  favorites       Favorite[]
  farm            Farm?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  title         String      @unique
  slug          String      @unique
  description   String
  cut           MeatType
  category      Category
  mainImage     String
  images        String[]
  price         Decimal     @default(0) @db.Decimal(10, 2) // تعديل إلى Decimal للدقة المالية
  discount      Int?        @default(0)
  unit          Unit        @default(كجم) // اللحوم تباع بالوزن غالباً كإجراء افتراضي
  stock         Decimal     @default(0) @db.Decimal(10, 2) // تعديل إلى Decimal لحسابات تشفي الأوزان
  lowQuantity   Decimal?    @default(0) @db.Decimal(10, 2)
  increaseByOne Boolean     @default(false)
  isActive      Boolean     @default(true) // مضاف: لإيقاف البيع دون حذف المنتج وتخريب سجل الطلبات القديمة
  orderItems    OrderItem[]
  favorites     Favorite[]
  cattleId      String? // جعلناه اختياري لبيع المصنعات أو الدواجن أو اللحوم العامة دون ربطها برأس ماشية عينية
  Cattle        Cattle?     @relation(fields: [cattleId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([cut])
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  manager   User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  cattle    Cattle[]
  country   String? // تصحيح الخطأ الإملائي conuntry -> country
  state     String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Breed {
  id             String   @id @default(cuid())
  title          String
  description    String?
  conversionRate Decimal? @db.Decimal(10, 2)
  image          String
  images         String[]
  cattle         Cattle[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Cattle {
  id         String     @id @default(cuid())
  farm       Farm       @relation(fields: [farmId], references: [id])
  farmId     String
  breed      Breed      @relation(fields: [breedId], references: [id])
  breedId    String
  type       CattleType @default(بقري)
  gender     Gender     @default(ذكر)
  age        Age        @default(صغير)
  liveWeight Decimal?   @db.Decimal(10, 2) // مضاف: الوزن القائم للرأس وهو أساسي للمزارع والتجارة
  costPrice  Decimal?   @db.Decimal(10, 2) // مضاف: تكلفة شراء الرأس لحساب الأرباح بدقة
  product    Product[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     Int           @unique @default(autoincrement())
  subTotal        Decimal       @db.Decimal(10, 2) // تعديل إلى Decimal منعاً لكسور الـ Float المالية
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  shippingAddress String
  customerNotes   String? // مثال: "تقطيع المكعبات صغير للطبخ"
  butcherNotes    String? // ملاحظات داخلية للجزار أثناء التجهيز والتعبئة والتشفية
  items           OrderItem[]
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id                String      @id @default(cuid())
  preparation       Preparation
  quantity          Decimal     @db.Decimal(10, 2) // الكمية المطلوبة (بالوزن أو القطعة)
  price             Decimal     @db.Decimal(10, 2) // سعر المنتج وقت الشراء الفعلي لضمان ثبات التقارير المالية
  requestedQuantity Decimal     @db.Decimal(10, 2) // الوزن المحجوز من الموقع (مثال: 1.00 كجم)
  actualQuantity    Decimal?    @db.Decimal(10, 2) // الوزن الحقيقي الخارج من الميزان بعد التشفية (مثال: 1.050 كجم)
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade) // حذف العناصر تلقائياً عند حذف الطلب
  orderId           String
  product           Product     @relation(fields: [productId], references: [id], onDelete: Restrict) // منع حذف المنتج إذا كان متواجداً في طلبات قديمة
  productId         String
}

model Favorite {
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // إذا حُذف المنتج تُحذف من المفضلة
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // إذا حُذف المستخدم تُحذف مفضلته
  userId    String
  createdAt DateTime @default(now())

  @@id([userId, productId])
}

enum CattleType {
  بقري
  جاموسي
  ماعز
  غنم
  جملي
}

enum Age {
  صغير // لباني
  وسيط // كاسر جوز / أربعة
  كبير // جامع
}

enum Gender {
  ذكر
  أنثى
}

enum MeatType {
  سن
  موزة
  ريش
  وش_فخدة
  ضهر_فخدة
  سمانة
  انتركوت
  تربيانكو
  لوحة_الكتف
  دوش
  كبدة
  قلب
  كلاوي
  فلتو
  مصنعات
  صدور_دواجن // مضاف: لدعم تصنيف الدواجن الجديد
  أوراك_دواجن // مضاف: لدعم تصنيف الدواجن الجديد
}

enum Preparation {
  بفتيك
  ستيك
  مكعبات
  كباب_حلة
  شرائح
  مفروم
  كامل // مضاف: لقطعيات مثل العروق كاملة أو الطيور الكاملة
}

enum Role {
  ADMIN
  USER
  CLIENT
  SUPPLIER
}

enum Category {
  MEAT
  PROCESSED
  CHICKEN
}

enum Unit {
  كجم
  قطعة
}

enum OrderStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  VISA
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
