generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/generated"
  useMultipleFiles                 = true
  writeNullishInModelTypes         = true
  createModelTypes                 = true
  // default is true
  writeBarrelFiles                 = false
  // default is true
  createInputTypes                 = false
  // default is true
  addInputTypeValidation           = false
  // default is true
  addIncludeType                   = false
  // default is true
  addSelectType                    = false
  // default is true
  validateWhereUniqueInput         = false
  // default is true
  createOptionalDefaultValuesTypes = false
  // default is false
  createRelationValuesTypes        = false
  // default is false
  createPartialTypes               = false
  // default is false
  useDefaultValidators             = false
  // default is true
  coerceDate                       = false
  // default is true
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  // output   = "./src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique // <--- THIS IS THE CRITICAL LINE
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  image           String?
  role            Role            @default(USER)
  accounts        Account[]
  sessions        Session[]
  Authenticator   Authenticator[]
  personalId      String?
  primaryMobile   String?         @unique
  secondaryMobile String?
  country         String?
  state           String?
  city            String?
  detailedAddress String?
  orders          Order[]
  favorites       Favorite[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// TODO 
model Product {
  id            String      @id @default(cuid())
  title         String      @unique
  slug          String      @unique
  description   String
  cut           MeatType
  category      Category
  mainImage     String
  images        String[]
  price         Float       @default(0)
  discount      Int?        @default(0)
  unit          Unit?       @default(قطعة)
  quantity      Float       @default(0)
  lowQuantity   Float?      @default(0)
  increaseByOne Boolean     @default(false)
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  favorites     Favorite[]
}

enum MeatType {
  سن
  موزة
  ريش
  وش_فخدة
  ضهر_فخدة
  سمانة
  انتركوت
  تربيانكو
  لوحة_الكتف
  دوش
  كبدة
  قلب
  كلاوي
  فلتو
  مصنعات
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   Int           @unique @default(autoincrement())
  subTotal      Float // إجمالي المنتجات قبل الشحن
  deliveryFee   Float         @default(0) // مصاريف الشحن والتوصيل
  total         Float // الإجمالي النهائي الفعلي (subTotal + deliveryFee)
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH) // الكاش هو الأكثر شيوعاً في اللحوم بمصر
  paymentStatus PaymentStatus @default(PENDING)

  // حقول التوصيل والملاحظات التشغيلية الحيوية
  shippingAddress String // العنوان التفصيلي للشحنة الحالية
  customerNotes   String? // ملاحظات الزبون (مثال: "تقطيع المكعبات صغير للطبخ")
  butcherNotes    String? // ملاحظات داخلية للجزار أثناء التجهيز والتعبئة

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User?       @relation(fields: [userId], references: [id])
  userId    String?
}

model OrderItem {
  id                String      @id @default(cuid())
  preparation       Preparation
  quantity          Float
  // نصيحة أمنية: لاتعتمد على سعر النتج الحالي في جدول المنتجات عند عرض المنتجات القديمة
  // لأنك لو غيرت السعر غدا ستتغير قيمة الطلبات التي تمت سابقا، يجب تخزين السعر وقت الشراء.
  price             Float // تم اضافة حقل السعر هنا ليكون محدث لآخر سعر للمنتج، 
  requestedQuantity Float // الوزن الذي طلبه العميل من الموقع (مثال: 1.00 كجم)
  actualQuantity    Float? // الوزن الحقيقي الذي خرج من الميزان بعد التشفيه (مثال: 1.050 كجم)
  order             Order       @relation(fields: [orderId], references: [id])
  orderId           String
  product           Product     @relation(fields: [productId], references: [id])
  productId         String
}

enum Preparation {
  بفتيك
  ستيك
  مكعبات
  كباب_حلة
  شرائح
  مفروم
}

// يفضل استخدام "Explicit Many-to-Many" (جدول وسيط صريح).
// لماذا؟ لتتمكن من معرفة "متى" قام العميل بإضافة المنتج للمفضلة، ولضمان أداء أفضل عند الاستعلام.
model Favorite {
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // إذا حُذف الطلب، تُحذف عناصره تلقائياً
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // إذا حُذف الطلب، تُحذف عناصره تلقائياً
  userId    String
  createdAt DateTime @default(now())

  @@id([userId, productId]) // منع تكرار نفس المنتج لنفس العميل
}

enum Role {
  ADMIN
  USER
  CLIENT
  SUPPLIER
}

enum Category {
  MEAT
  PROCESSED
  CHICKEN
}

enum Unit {
  كجم
  قطعة
}

enum OrderStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  VISA
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
